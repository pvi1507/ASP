@model List<BC_ASP.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
    decimal subTotal = Model?.Sum(x => x.Quantity * (x.Product?.Price ?? 0)) ?? 0;
    decimal discount = 0;
    decimal grandTotal = subTotal - discount;
}

<div class="hero-section" style="height: 280px;">
    <div class="hero-background">
        <img src="~/images/hero-cake.jpg" alt="Giỏ hàng Banner">
    </div>

    <div class="products-hero-overlay"></div>
    <div class="container">
        <div class="products-hero-content text-center text-white">
            <h1 class="products-hero-title">Giỏ Hàng Của Bạn</h1>
            <p class="products-hero-subtitle">@(Model?.Count ?? 0) sản phẩm</p>
        </div>
    </div>
</div>

@if (Model == null || Model.Count == 0)
{
    <section class="py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-6 text-center py-5">
                    <div class="empty-state-icon mb-4">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                    <h2 class="empty-state-title">Giỏ hàng trống</h2>
                    <p class="empty-state-text mb-4">Chưa có sản phẩm nào trong giỏ hàng.</p>
                    <div class="d-grid gap-2 d-md-flex justify-content-center">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg">
                            <i class="fas fa-store me-2"></i>Tiếp tục mua sắm
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
}
else
{
    <section class="py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="row g-3">
                        @foreach (var item in Model)
                        {
                            <div class="col-12">
                                <div class="cart-item-card p-4 rounded-4 shadow-sm" style="background: var(--white); border: 1px solid #eee;">
                                    <div class="row align-items-center g-4">
                                        <div class="col-md-2">
                                            
                                            @{
                                                string imagePath = $"/images/products/{item.ProductId}.jpg";
                                            }

                                            <img src="@imagePath" alt="@(item.Product?.Name ?? "Sản phẩm")" class="img-fluid rounded-3 shadow-sm" style="height: 100px; width: 100px; object-fit: cover;"
                                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                                 
                                            <div class="bg-light rounded-3 align-items-center justify-content-center" style="height: 100px; width: 100px; display: none;">
                                                <i class="fas fa-birthday-cake text-primary fs-2"></i>
                                            </div>
                                            
                                        </div>

                                        <div class="col-md-5">
                                            <h5 class="product-title mb-1">
                                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="text-dark text-decoration-none">@(item.Product?.Name ?? "Sản phẩm")</a>
                                            </h5>
                                            <span class="badge bg-light text-dark">@(item.Product?.Category?.Name ?? "Không danh mục")</span>
                                            <p class="text-muted small mb-0">Giá: @String.Format("{0:N0} VNĐ", item.Product?.Price ?? 0)</p>
                                        </div>

                                        <div class="col-md-2">
                                            <form asp-action="Update" method="post" class="qty-form">
                                                <input type="hidden" name="productId" value="@item.ProductId">
                                                <div class="input-group input-group-sm" style="max-width: 120px;">
                                                    <button type="button" class="btn btn-outline-secondary qty-btn" onclick="changeQty(this, -1)">
                                                        <i class="fas fa-minus"></i>
                                                    </button>
                                                    <input type="number" name="quantity" value="@item.Quantity" min="1" max="@(item.Product?.Stock ?? 999)" class="form-control text-center qty-input" readonly>
                                                    <button type="button" class="btn btn-outline-secondary qty-btn" onclick="changeQty(this, 1)">
                                                        <i class="fas fa-plus"></i>
                                                    </button>
                                                </div>
                                            </form>
                                        </div>

                                        <div class="col-md-3 text-end">
                                            <div class="h5 mb-2 fw-bold text-primary">@String.Format("{0:N0}", item.Quantity * (item.Product?.Price ?? 0)) VNĐ</div>
                                            <form asp-action="Remove" method="post" class="remove-form d-inline">
                                                <input type="hidden" name="productId" value="@item.ProductId">
                                                <button type="submit" class="btn btn-sm btn-outline-danger remove-btn" onclick="return confirm('Xóa @(item.Product?.Name ?? "Sản phẩm") khỏi giỏ hàng?')">
                                                    <i class="fas fa-trash"></i> Xóa
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="cart-summary-card sticky-top" style="top: 100px;">
                        <div class="card rounded-4 shadow-lg border-0">
                            <div class="card-header bg-primary text-white rounded-top-4">
                                <h5 class="mb-0"><i class="fas fa-receipt me-2"></i>Tóm tắt đơn hàng</h5>
                            </div>
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between mb-3">
                                    <span>Tạm tính (@(Model?.Count ?? 0) sản phẩm):</span>
                                    <span>@String.Format("{0:N0}", subTotal) VNĐ</span>
                                </div>
                                <div class="d-flex justify-content-between mb-4">
                                    <span>Giảm giá:</span>
                                    <span class="text-success">- @String.Format("{0:N0}", discount) VNĐ</span>
                                </div>
                                <hr>
                                <div class="d-flex justify-content-between h4 mb-4 fw-bold">
                                    <span>Tổng tiền:</span>
                                    <span class="text-primary">@String.Format("{0:N0}", grandTotal) VNĐ</span>
                                </div>
                                <a asp-action="Checkout" class="btn btn-primary btn-lg w-100 mb-3">
                                    <i class="fas fa-credit-card me-2"></i>Tiến hành thanh toán
                                </a>
                                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary w-100">
                                    <i class="fas fa-store me-2"></i>Tiếp tục mua sắm
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

@section Scripts {
    <script>
        function changeQty(btn, delta) {
            const input = btn.parentElement.querySelector('.qty-input');
            let val = parseInt(input.value) || 1;
            val = Math.max(1, Math.min(val + delta, parseInt(input.max)));
            input.value = val;
            input.parentElement.parentElement.submit();
        }
    </script>
    <partial name="_ValidationScriptsPartial" />
}