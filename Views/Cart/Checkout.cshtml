@model object
@{
    ViewData["Title"] = "Thanh toán";
    
    var product = ViewBag.Product as BC_ASP.Models.Product;
    var quantity = (int?)ViewBag.Quantity ?? 1;
    var total = (decimal?)ViewBag.Total ?? 0;
}

@if (product == null)
{
    <div class="alert alert-danger">
        <h4>Lỗi: Sản phẩm không tồn tại!</h4>
        <a asp-action="Index" asp-controller="Product" class="btn btn-primary">Chọn sản phẩm khác</a>
    </div>
}
else
{
<div class="hero-section" style="height: 280px;">
    <div class="hero-background">
        <img src="~/images/hero-cake.jpg" alt="Thanh toán">
    </div>
    <div class="products-hero-overlay"></div>
    <div class="container">
        <div class="products-hero-content text-center text-white">
            <h1 class="products-hero-title">Thanh toán</h1>
            <p class="products-hero-subtitle">Nhập thông tin để hoàn tất đơn hàng</p>
        </div>
    </div>
</div>

<section class="py-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-8">
                <form asp-action="CheckoutSubmit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@product.Id" />
                    <input type="hidden" name="quantity" value="@quantity" />
                    
                    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                        <div class="card-header bg-primary text-white py-4">
                            <h4 class="mb-0"><i class="fas fa-user me-3"></i>Thông tin giao hàng</h4>
                        </div>
                        <div class="card-body p-5">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Họ tên *</label>
                                    <input type="text" name="customerName" class="form-control" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Số điện thoại *</label>
                                    <input type="tel" name="customerPhone" class="form-control" required>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-bold">Email *</label>
                                    <input type="email" name="customerEmail" class="form-control" required>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-bold">Địa chỉ giao hàng *</label>
                                    <textarea name="shippingAddress" class="form-control" rows="3" required placeholder="Số nhà, đường, phường, quận, tỉnh..."></textarea>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Ghi chú đơn hàng</label>
                                    <textarea name="note" class="form-control" rows="2" placeholder="Yêu cầu đặc biệt (không đường, giao sớm...)"></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-light border-0 py-4">
                            <button type="submit" class="btn btn-success btn-lg px-5">
                                <i class="fas fa-check me-2"></i>Hoàn tất đặt hàng
                            </button>
                            <a asp-action="Index" asp-controller="Product" class="btn btn-outline-secondary ms-3">Chọn sản phẩm khác</a>
                        </div>
                    </div>
                </form>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-lg border-0 rounded-4 sticky-top" style="top: 100px;">
                    <div class="card-header bg-success text-white py-4 rounded-top-4">
                        <h5 class="mb-0"><i class="fas fa-receipt me-2"></i>Tóm tắt đơn hàng</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="product-summary mb-4">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name" class="img-fluid rounded mb-3" style="max-height: 120px; object-fit: cover;">
                            }
                            <h6 class="fw-bold">@product.Name</h6>
                            <p class="text-muted small mb-2">SL: @quantity x @product.Price.ToString("N0") VNĐ</p>
                            <div class="border-top pt-3 mt-3">
                                <div class="d-flex justify-content-between h4 mb-0 fw-bold">
                                    <span>Tổng cộng</span>
                                    <span class="text-primary">@total.ToString("N0") VNĐ</span>
                                </div>
                                <small class="text-muted d-block mt-1">Phí ship sẽ tính sau</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
}
