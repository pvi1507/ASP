@model BC_ASP.Models.ApplicationUser
@{
    ViewData["Title"] = "Thông tin tài khoản";
}

<h1 class="section-title text-center">Thông tin tài khoản</h1>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Họ tên</dt>
                    <dd class="col-sm-9">@Model.FullName</dd>
                    
                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@Model.Email</dd>
                    
                    <dt class="col-sm-3">Địa chỉ</dt>
                    <dd class="col-sm-9">@Model.Address</dd>
                    
                    <dt class="col-sm-3">Ngày tạo</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy")</dd>
                </dl>
                
                <div class="text-center">
                    <a asp-action="ChangePassword" class="btn btn-primary">Đổi mật khẩu</a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Quay lại</a>
                </div>
            </div>
        </div>
    </div>
</div>

