@model BC_ASP.Models.Category
@{
    ViewData["Title"] = "Chi tiết danh mục";
}

<h1>Chi tiết danh mục</h1>

<div>
    <hr>
    <dl class="row">
        <dt class="col-sm-2">Tên danh mục</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Mô tả</dt>
        <dd class="col-sm-10">@Model.Description</dd>
        <dt class="col-sm-2">Trạng thái</dt>
        <dd class="col-sm-10">
            @if (Model.IsActive)
            {
                <span class="badge bg-success">Hoạt động</span>
            }
            else
            {
                <span class="badge bg-secondary">Không hoạt động</span>
            }
        </dd>
        <dt class="col-sm-2">Số sản phẩm</dt>
        <dd class="col-sm-10">@Model.Products?.Count</dd>
    </dl>
</div>

<div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Sửa</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Xóa</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>

