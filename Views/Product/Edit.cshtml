@model BC_ASP.Models.Product
@{
    ViewData["Title"] = "Sửa sản phẩm";
}

<h1>Sửa sản phẩm</h1>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id">
    <div class="row">
        <div class="col-md-8">
            <div class="mb-3">
                <label class="form-label">Tên sản phẩm</label>
                <input asp-for="Name" class="form-control" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Giá</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Số lượng tồn kho</label>
                <input asp-for="Stock" class="form-control" type="number" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Danh mục</label>
                <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-select"></select>
            </div>
<div class="mb-3">
                <label class="form-label">Tải lên hình ảnh mới (giữ ảnh cũ nếu không chọn)</label>
                <input type="file" name="ImageFile" class="form-control" accept="image/*">
                <div class="form-text">Tải lên ảnh JPG/PNG (tối đa 5MB)</div>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsFeatured" class="form-check-input">
                <label class="form-check-label">Sản phẩm nổi bật</label>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsActive" class="form-check-input">
                <label class="form-check-label">Hoạt động</label>
            </div>
        </div>
    </div>
    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

