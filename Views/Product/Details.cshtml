@model BC_ASP.Models.Product
@{
    ViewData["Title"] = Model.Name;
}

<div class="hero-section" style="height: 300px;">
    <div class="hero-background">
        <img src="~/images/hero-cake.jpg" alt="Sản phẩm chi tiết">
    </div>

    <div class="products-hero-overlay" style="background: rgba(0,0,0,0.3);"></div>
    <div class="container position-relative">
        <div class="products-hero-content text-center text-white">
            <div class="products-hero-breadcrumb">
                <a asp-controller="Home" asp-action="Index" class="text-light">Trang chủ</a>
                <span class="mx-2">/</span>
                <a asp-controller="Product" asp-action="Index" class="text-light">Sản phẩm</a>
                <span class="mx-2">/</span>
                <span>@Model.Name</span>
            </div>
            <h1 class="products-hero-title mt-2">@Model.Name</h1>
            @if (Model.Category != null)
            {
                <span class="badge bg-primary fs-6 px-3 py-2">@Model.Category.Name</span>
            }
        </div>
    </div>
</div>

<section class="py-5" style="background: var(--bg-cream);">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-6">
                <div class="product-gallery position-relative">
                    
                    @{
                        string imagePath = $"/images/products/{Model.Id}.jpg";
                    }

                    <img src="@imagePath" alt="@Model.Name" class="img-fluid rounded-4 shadow-lg w-100" style="height: 500px; object-fit: cover;"
                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                         
                    <div class="bg-light rounded-4 align-items-center justify-content-center" style="height: 500px; display: none;">
                        <i class="fas fa-birthday-cake text-primary" style="font-size: 150px; opacity: 0.5;"></i>
                    </div>

                    <div class="position-absolute top-20 start-0">
                        @if (Model.IsFeatured)
                        {
                            <span class="badge-hot fs-6 px-3 py-2 me-2 mb-2 d-block">🔥 Hot</span>
                        }
                        @if (Model.Stock <= 0)
                        {
                            <span class="badge-soldout fs-6 px-3 py-2">❌ Hết hàng</span>
                        }
                        else if (Model.Stock < 5)
                        {
                            <span class="badge-low fs-6 px-3 py-2">⚠️ Chỉ còn @Model.Stock</span>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="product-info-card p-5 rounded-4 shadow-lg" style="background: var(--white); height: fit-content;">
                    <div class="d-flex align-items-center mb-4">
                        <div class="product-rating me-3">
                            @{
                                var fullStars = (int)Model.AverageRating;
                                var hasHalfStar = Model.AverageRating % 1 >= 0.5;
                            }
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= fullStars)
                                {
                                    <i class="fas fa-star text-warning"></i>
                                }
                                else if (i == fullStars + 1 && hasHalfStar)
                                {
                                    <i class="fas fa-star-half-alt text-warning"></i>
                                }
                                else
                                {
                                    <i class="far fa-star text-warning"></i>
                                }
                            }
                            <span class="ms-2 fw-bold text-dark">@Model.AverageRating.ToString("F1") (@Model.ReviewCount đánh giá)</span>
                        </div>
                    </div>

                    <h1 class="product-title mb-3">@Model.Name</h1>
                    <div class="product-price-box mb-4">
                        <span class="h2 text-primary fw-bold">@String.Format("{0:N0}", Model.Price) <small class="fs-5 text-muted">VNĐ</small></span>
                    </div>

                    <div class="product-meta mb-4">
                        <div class="d-flex align-items-center mb-3">
                            <i class="fas fa-layer-group text-primary me-3"></i>
                            <span class="fw-semibold">Danh mục:</span> @Model.Category?.Name
                        </div>
                        <div class="d-flex align-items-center mb-4">
                            <i class="fas fa-box text-primary me-3"></i>
                            <span class="fw-semibold">Tồn kho:</span>
                            @if (Model.Stock > 0)
                            {
                                <span class="badge bg-success ms-2">@Model.Stock sản phẩm</span>
                            }
                            else
                            {
                                <span class="badge bg-danger ms-2">Hết hàng</span>
                            }
                        </div>
                    </div>

                    <div class="product-description mb-4">
                        <h5 class="fw-bold mb-3"><i class="fas fa-align-left me-2"></i>Mô tả sản phẩm</h5>
                        <p class="lead">@Model.Description</p>
                    </div>

@if (!User.IsInRole("Admin") && !User.IsInRole("Employee") && User.Identity.IsAuthenticated && Model.Stock > 0)
                    {
                        <div class="buy-box p-4 rounded-3 mb-4" style="background: linear-gradient(135deg, var(--primary-light), #fff);">
                            <h5 class="mb-3 fw-bold">Thêm vào giỏ hàng</h5>
                            <form asp-controller="Cart" asp-action="Add" asp-route-productId="@Model.Id" method="post" class="row g-3 align-items-end">
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Số lượng</label>
                                    <input type="number" name="quantity" value="1" min="1" max="@Model.Stock" class="form-control" style="border-radius: 12px;">
                                </div>
                                <div class="col-md-8">
                                    <button type="submit" class="btn w-100 btn-lg" style="background: linear-gradient(135deg, var(--primary-color), var(--primary-dark)); border: none; border-radius: 25px; color: white; font-weight: 600;">
                                        <i class="fas fa-shopping-cart me-2"></i>
                                        Thêm vào giỏ hàng
                                    </button>
                                </div>
                            </form>
                        </div>
                    }
                    else if (!User.IsInRole("Admin") && !User.IsInRole("Employee") && !User.Identity.IsAuthenticated)
                    {
                        <div class="buy-box p-4 rounded-3 mb-4 text-center" style="background: linear-gradient(135deg, var(--primary-light), #fff);">
                            <h5 class="mb-4">Đăng nhập để mua hàng</h5>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-5">
                                <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập ngay
                            </a>
                        </div>
                    }
                    else if (!User.IsInRole("Admin") && !User.IsInRole("Employee") && Model.Stock <= 0)
                    {
                        <div class="buy-box p-4 rounded-3 text-center" style="background: linear-gradient(135deg, #f8d7da, #fff); border: 2px dashed #dc3545;">
                            <i class="fas fa-exclamation-triangle text-danger mb-3" style="font-size: 48px;"></i>
                            <h5 class="text-danger">Sản phẩm đã hết hàng</h5>
                            <p class="mb-4">Chúng tôi sẽ cập nhật sớm!</p>
                            <a asp-action="Index" class="btn btn-outline-primary">Xem sản phẩm khác</a>
                        </div>
                    }

                    <div class="product-actions mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary me-2">
                            <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
                        </a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                                <i class="fas fa-edit me-1"></i>Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger" onclick="return confirm('Xóa sản phẩm này?')">
                                <i class="fas fa-trash me-1"></i>Xóa
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container">
        <h2 class="section-title text-center mb-5">Đánh giá & Nhận xét</h2>
        <div class="row">
            <div class="col-12">
                @if (!User.Identity.IsAuthenticated)
                {
                    <div class="alert alert-info mb-5">
                        <i class="fas fa-star me-2"></i>
                        <strong>Đăng nhập</strong> để có thể đánh giá sản phẩm!
                        <a asp-controller="Account" asp-action="Login" class="alert-link ms-2">Đăng nhập ngay</a>
                    </div>
                }
                else
                {
                    <!-- Review Form -->
                    <div class="card mb-5 border-0 shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-star me-2"></i>Đánh giá sản phẩm của bạn</h5>
                        </div>
                        <div class="card-body">
                            <form id="reviewForm">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@Model.Id" />
                                <div class="mb-4">
                                    <label class="form-label fw-bold">Điểm đánh giá của bạn:</label>
                                    <div class="star-rating mt-2" data-rating="0">
                                        <i class="far fa-star star" data-value="1"></i>
                                        <i class="far fa-star star" data-value="2"></i>
                                        <i class="far fa-star star" data-value="3"></i>
                                        <i class="far fa-star star" data-value="4"></i>
                                        <i class="far fa-star star" data-value="5"></i>
                                    </div>
                                    <input type="hidden" id="rating" name="rating" value="0" required />
                                    <div class="form-text">Nhấp vào sao để đánh giá (1-5 sao)</div>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold">Nhận xét của bạn:</label>
                                    <textarea name="comment" rows="4" class="form-control" placeholder="Chia sẻ trải nghiệm của bạn về sản phẩm này..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary btn-lg px-5">
                                    <i class="fas fa-paper-plane me-2"></i>Gửi đánh giá
                                </button>
                            </form>
                        </div>
                    </div>
                }

                <!-- Reviews List -->
                @if (Model.Reviews.Any())
                {
                    <h4 class="mb-4">Các đánh giá khác (@Model.Reviews.Count())</h4>
                    @foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt).Take(10))
                    {
                        <div class="review-item p-4 mb-4 border rounded-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    @for (int i = 1; i <= review.Rating; i++)
                                    {
                                        <i class="fas fa-star text-warning"></i>
                                    }
                                    @for (int i = review.Rating + 1; i <= 5; i++)
                                    {
                                        <i class="far fa-star text-secondary"></i>
                                    }
                                    <span class="ms-2 text-muted small">(@review.Rating/@Model.AverageRating.ToString("F1") sao)</span>
                                </div>
                                <small class="text-muted">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <h6 class="fw-bold mb-1">@review.User.FullName</h6>
                            @if (!string.IsNullOrEmpty(review.Comment))
                            {
                                <p class="mb-0 text-muted">@review.Comment</p>
                            }
                        </div>
                    }
                    @if (Model.Reviews.Count() > 10)
                    {
                        <div class="text-center">
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary">Xem thêm đánh giá</a>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-comments text-muted mb-3" style="font-size: 4rem;"></i>
                        <h5 class="text-muted">Chưa có đánh giá nào</h5>
                        <p class="text-muted">Hãy là người đầu tiên đánh giá sản phẩm này!</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const stars = document.querySelectorAll('.star');
    const ratingInput = document.getElementById('rating');
    
    stars.forEach(star => {
        star.addEventListener('click', function() {
            const value = parseInt(this.dataset.value);
            ratingInput.value = value;
            
            stars.forEach(s => s.classList.remove('fas', 'text-warning'));
            stars.forEach(s => s.classList.add('far'));
            
            for (let i = 1; i <= value; i++) {
                stars[i-1].classList.remove('far');
                stars[i-1].classList.add('fas', 'text-warning');
            }
        });
        
        star.addEventListener('mouseover', function() {
            const value = parseInt(this.dataset.value);
            stars.forEach((s, index) => {
                if (index < value) {
                    s.classList.remove('far');
                    s.classList.add('fas', 'text-warning');
                } else {
                    s.classList.remove('fas', 'text-warning');
                    s.classList.add('far');
                }
            });
        });
    });
    
    document.querySelector('.star-rating').addEventListener('mouseleave', function() {
        const currentRating = parseInt(ratingInput.value);
        stars.forEach((s, index) => {
            if (index < currentRating) {
                s.classList.remove('far');
                s.classList.add('fas', 'text-warning');
            } else {
                s.classList.remove('fas', 'text-warning');
                s.classList.add('far');
            }
        });
    });
    
    document.getElementById('reviewForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        if (document.getElementById('rating').value == '0') {
            alert('Vui lòng chọn số sao đánh giá!');
            return;
        }
        
        const formData = new FormData(this);
        const response = await fetch('/Product/ReviewCreate', {
            method: 'POST',
            body: formData
        });
        
        const result = await response.json();
        if (result.success) {
            alert(result.message);
            location.reload();
        } else {
            alert(result.message);
        }
    });
});
</script>
