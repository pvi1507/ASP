<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Geewonii Bakery</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Navbar Modern - Fixed Top with Search, Cart, User Dropdown -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm fixed-top" style="z-index: 1030;">
        <div class="container">
            <!-- Brand -->
            <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
                <i class="fas fa-birthday-cake text-primary me-2"></i>
                <span class="text-dark">Geewonii</span><span class="text-primary">Bakery</span>
            </a>
            
            <!-- Toggler -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <!-- Collapsible -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-home me-1"></i> Trang chủ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Index">
                            <i class="fas fa-cake-candles me-1"></i> Sản phẩm
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Category" asp-action="Index">
                            <i class="fas fa-layer-group me-1"></i> Danh mục
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Contact" asp-action="Index">
                            <i class="fas fa-phone me-1"></i> Liên hệ
                        </a>
                    </li>
                </ul>

                <!-- Search & Cart & User -->
                <div class="d-flex align-items-center gap-3">
                    <!-- Search -->
                    <form asp-controller="Product" asp-action="Search" method="get" class="d-flex">
                        <div class="input-group input-group-sm" style="width: 250px;">
                            <input type="search" class="form-control border-end-0" name="searchString" placeholder="Tìm bánh kem..." />
                            <span class="input-group-text bg-white border-start-0">
                                <i class="fas fa-search text-muted"></i>
                            </span>
                        </div>
                    </form>

                    <!-- Cart -->
                    <a asp-controller="Cart" asp-action="Index" class="position-relative nav-link p-0">
                        <i class="fas fa-shopping-cart fs-5"></i>
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            var cartCount = Context.Session.GetInt32("CartCount") ?? 0;
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                @cartCount<span class="visually-hidden">items in cart</span>
                            </span>
                        }
                    </a>

                    <!-- User Menu -->
                    @await Component.InvokeAsync("UserName")
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content with padding for fixed navbar -->
    <main role="main" class="pt-5">
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }

        @RenderBody()
    </main>

    <!-- Footer Modern Dark -->
    <footer class="footer bg-dark text-light py-5 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">

<div class="footer-brand">
    <i class="fas fa-birthday-cake text-primary fs-1 mb-2"></i>
    <h4 class="mb-3 fw-bold">Geewonii Bakery</h4>
    <p class="mb-4">Nơi hội tụ đam mê và nghệ thuật làm bánh. Mang đến những chiếc bánh kem thơm ngon nhất cho ngày đặc biệt của bạn.</p>
    <div class="social-links d-flex gap-3 justify-content-start">
        <a href="#" class="text-light social-icon" title="Facebook"><i class="fab fa-facebook-f fs-4"></i></a>
        <a href="#" class="text-light social-icon" title="Instagram"><i class="fab fa-instagram fs-4"></i></a>
        <a href="#" class="text-light social-icon" title="YouTube"><i class="fab fa-youtube fs-4"></i></a>
        <a href="#" class="text-light social-icon" title="TikTok"><i class="fab fa-tiktok fs-4"></i></a>
    </div>
</div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h5 class="footer-title">Menu</h5>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="Index" class="text-light text-decoration-none"><i class="fas fa-chevron-right me-2"></i>Trang chủ</a></li>
                        <li><a asp-controller="Product" asp-action="Index" class="text-light text-decoration-none"><i class="fas fa-chevron-right me-2"></i>Sản phẩm</a></li>
                        <li><a asp-controller="Category" asp-action="Index" class="text-light text-decoration-none"><i class="fas fa-chevron-right me-2"></i>Danh mục</a></li>
                        <li><a asp-controller="Cart" asp-action="Index" class="text-light text-decoration-none"><i class="fas fa-chevron-right me-2"></i>Giỏ hàng</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h5 class="footer-title">Liên hệ</h5>
                    <ul class="list-unstyled">
                        <li><i class="fas fa-map-marker-alt me-2"></i>419 Đường 30/4, TP.Cần Thơ</li>
                        <li><i class="fas fa-phone me-2"></i>0356 034 510</li>
                        <li><i class="fas fa-envelope me-2"></i>vix5533@gmail.com</li>
                        <li><i class="fas fa-clock me-2"></i>8:00 - 20:00 (T2-CN)</li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h5 class="footer-title">Dịch vụ</h5>
                    <ul class="list-unstyled">
                        <li><i class="fas fa-chevron-right me-2"></i>Đặt bánh sinh nhật</li>
                        <li><i class="fas fa-chevron-right me-2"></i>Bánh cưới</li>
                        <li><i class="fas fa-chevron-right me-2"></i>Bánh sự kiện</li>
                        <li><i class="fas fa-chevron-right me-2"></i>Giao hàng tận nơi</li>
                    </ul>
                </div>
            </div>
            <hr class="my-4 opacity-25">
            <div class="text-center">
                <p class="mb-0">&copy; 2026 Geewonii Bakery. Tất cả quyền được bảo lưu. 
                    <i class="fas fa-heart text-danger"></i> bởi Huỳnh Phương Vĩ
                </p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

