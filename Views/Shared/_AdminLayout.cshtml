
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Geewonii Bakery Admin</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="admin-body">
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="sidebar bg-dark text-white p-3 vh-100" style="width: 250px; position: fixed; height: 100vh; z-index: 1030;">
            <div class="sidebar-brand text-center pb-4">
                <h4 class="text-primary mb-0">
                    <i class="fas fa-cake-candles me-2"></i>
                    Admin Panel
                </h4>
            </div>

    <nav class="nav flex-column">
        <a class="nav-link text-white fw-bold active-sidebar" asp-controller="Home" asp-action="AdminDashboard">
            <i class="fas fa-tachometer-alt me-2"></i> Dashboard
        </a>

                <a class="nav-link text-white" asp-controller="Category" asp-action="Index">
                    <i class="fas fa-layer-group me-2"></i> Danh mục
                </a>
                <a class="nav-link text-white" asp-controller="Product" asp-action="Index">
                    <i class="fas fa-cake-candles me-2"></i> Sản phẩm
                </a>
                <a class="nav-link text-white" asp-controller="Order" asp-action="Index">
                    <i class="fas fa-shopping-bag me-2"></i> Đơn hàng
                </a>
                <a class="nav-link text-white" asp-controller="Home" asp-action="ContactMessages">
                    <i class="fas fa-envelope me-2"></i> Tin nhắn liên hệ
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a class="nav-link text-white" asp-controller="Account" asp-action="UserList">
                        <i class="fas fa-users me-2"></i> Quản lý User
                    </a>
                }
                <hr class="bg-white my-3 opacity-25">
                <a class="nav-link text-white" asp-controller="Account" asp-action="Profile">
                    <i class="fas fa-user me-2"></i> Profile
                </a>

<form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="nav-link text-danger border-0 bg-transparent text-start w-100">
                        <i class="fas fa-sign-out-alt me-2"></i> Đăng xuất
                    </button>
                </form>

            </nav>
        </div>


        <!-- Main content -->
        <div class="flex-grow-1" style="margin-left: 250px; padding-top: 20px; min-height: 100vh;">
            <!-- Admin Breadcrumb/Nav -->
            <div class="admin-breadcrumb mb-4 bg-white rounded-3 p-3 shadow-sm">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-3">
                        <a asp-controller="Home" asp-action="AdminDashboard" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-tachometer-alt me-1"></i> Dashboard
                        </a>
                        <span class="breadcrumb-separator">/</span>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary btn-sm" onclick="location.reload()">
                            <i class="fas fa-sync-alt"></i>
                        </button>
                    </div>
                </div>
            </div>
            @RenderBody()
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

